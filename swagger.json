{
  "swagger": "2.0",
  "info": {
    "title": "Ammo API",
    "description": "Inventory management for firearms and ammunition",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/auth/google": {
      "get": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "description": "",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/firearms/": {
      "get": {
        "tags": [
          "Firearms"
        ],
        "description": "Retrieve all firearms from the database.",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Firearms"
        ],
        "description": "Create a new firearm entry.",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "Firearm Data",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nickname": {
                  "type": "string",
                  "example": "My Primary Rifle"
                },
                "manufacturer": {
                  "type": "string",
                  "example": "Daniel Defense"
                },
                "model": {
                  "type": "string",
                  "example": "DDM4 V7"
                },
                "serialNumber": {
                  "type": "string",
                  "example": "DD123456"
                },
                "caliber": {
                  "type": "string",
                  "example": "5.56 NATO"
                },
                "actionType": {
                  "type": "string",
                  "example": "Semi-Auto"
                },
                "category": {
                  "type": "string",
                  "example": "MSR"
                },
                "barrelLength": {
                  "type": "number",
                  "example": 16
                },
                "finish": {
                  "type": "string",
                  "example": "Black Anodized"
                },
                "purchaseDate": {
                  "type": "string",
                  "example": "2024-02-21"
                },
                "purchasePrice": {
                  "type": "number",
                  "example": 1800
                },
                "image": {
                  "type": "string",
                  "example": "https://example.com/image.jpg"
                },
                "notes": {
                  "type": "string",
                  "example": "Equipped with LPVO optic"
                },
                "ownerId": {
                  "type": "string",
                  "example": "user_123"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/firearms/{id}": {
      "get": {
        "tags": [
          "Firearms"
        ],
        "description": "Retrieve a single firearm by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": [
          "Firearms"
        ],
        "description": "Update an existing firearm by ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Firearm Data to Update",
            "schema": {
              "type": "object",
              "properties": {
                "nickname": {
                  "type": "string",
                  "example": "Updated Nickname"
                },
                "purchasePrice": {
                  "type": "number",
                  "example": 1750
                },
                "notes": {
                  "type": "string",
                  "example": "Added new sling"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "delete": {
        "tags": [
          "Firearms"
        ],
        "description": "Delete a firearm from the database.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/ammo/": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "description": "New Ammunition Data",
            "schema": {
              "type": "object",
              "properties": {
                "caliber": {
                  "type": "string",
                  "example": "This is a test of this"
                },
                "bulletWeight": {
                  "type": "number",
                  "example": 124
                },
                "bulletType": {
                  "type": "string",
                  "example": "HST JHP"
                },
                "brand": {
                  "type": "string",
                  "example": "Federal"
                },
                "category": {
                  "type": "string",
                  "example": "Handgun"
                },
                "quantity": {
                  "type": "number",
                  "example": 50
                },
                "muzzleVelocity": {
                  "type": "number",
                  "example": 1150
                },
                "lotNumber": {
                  "type": "string",
                  "example": "L123-A"
                },
                "notes": {
                  "type": "string",
                  "example": "Self-defense carry ammo"
                },
                "ownerId": {
                  "type": "string",
                  "example": "user_01"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/ammo/{id}": {
      "get": {
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Updated Ammunition Data",
            "schema": {
              "$ref": "#/definitions/Ammunition"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "delete": {
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  }
}